<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Fleet Dashboard</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <style>
        body { background-color: #0f1117; color: #e2e8f0; }
        .navbar { background-color: #1a1d2e; }
        .navbar-brand { color: #60a5fa !important; font-weight: 700; }
        .card { background-color: #1e2235; border: 1px solid #2d3250; }
        .card-header { background-color: #252942; border-bottom: 1px solid #2d3250; }
        .table { color: #e2e8f0; }
        .table-hover tbody tr:hover { background-color: #252942; }
        .badge-online  { background-color: #10b981; }
        .img-thumb {
            width: 100%;
            height: 160px;
            object-fit: cover;
            border-radius: 6px;
            cursor: pointer;
            transition: transform 0.15s ease;
        }
        .img-thumb:hover { transform: scale(1.04); }
        footer { color: #64748b; font-size: 0.8rem; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg mb-4">
        <div class="container">
            <a class="navbar-brand" asp-controller="Devices" asp-action="Index">
                🛰 Fleet Dashboard
            </a>
        </div>
    </nav>

    <main class="container">
        @RenderBody()
    </main>

    <footer class="container text-center mt-5 mb-3">
        <p>Raspberry Pi Fleet — Azure Government</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
